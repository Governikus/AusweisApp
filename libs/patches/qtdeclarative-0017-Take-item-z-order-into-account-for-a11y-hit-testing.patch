From e23b10d90eeb6d3957cc6e6dc36a07eb9b1a9809 Mon Sep 17 00:00:00 2001
From: Andreas Belke <andreas.belke@governikus.de>
Date: Wed, 21 Jan 2026 16:43:19 +0100
Subject: Take item z order into account for a11y hit testing

With changing the stacking order of the menuBar/header/footer to match
the tab navigation to the visual order (see 6afdf0e0), the menuBar and
header could no longer be focused on Android when TalkBack was enabled.

The ApplicationWindowContentControl is stacked above the menuBar and
header and takes up all the available space in the window. However, it
has a lower z value.

QtAndroidAccessibility::hitTest_helper always returns the
ApplicationWindowContentControl when touching the header and menuBar
because the drawing order is not evaluated.

With this change, the paint order is taken into account by using the
existing function accessibleUnignoredChildren(*item, paintOrder).

Pick-to: 6.11 6.10
Task-number: QTBUG-137823
Change-Id: I8aad6684b1e2f555fc0d46a3a51dc1fd5bf89350
---
 src/quick/accessible/qaccessiblequickview.cpp | 9 +++++++--
 1 file changed, 7 insertions(+), 2 deletions(-)

diff --git x/qtdeclarative/src/quick/accessible/qaccessiblequickview.cpp y/qtdeclarative/src/quick/accessible/qaccessiblequickview.cpp
index 145400c1261bbf4f3976431b028bf69720c4a5b9..018fa27473686e3e0fa8f0ecb606bb1b53c98de6 100644
--- x/qtdeclarative/src/quick/accessible/qaccessiblequickview.cpp
+++ y/qtdeclarative/src/quick/accessible/qaccessiblequickview.cpp
@@ -105,8 +105,13 @@ QString QAccessibleQuickWindow::text(QAccessible::Text text) const
 QAccessibleInterface *QAccessibleQuickWindow::childAt(int x, int y) const
 {
     Q_ASSERT(window());
-    for (int i = childCount() - 1; i >= 0; --i) {
-        QAccessibleInterface *childIface = child(i);
+
+    if (!window()->contentItem())
+        return nullptr;
+
+    const QList<QQuickItem *> kids = accessibleUnignoredChildren(window()->contentItem(), true);
+    for (int i = kids.size() - 1; i >= 0; --i) {
+        QAccessibleInterface *childIface = QAccessible::queryAccessibleInterface(kids.at(i));
         if (childIface && !childIface->state().invisible) {
             if (QAccessibleInterface *iface = childIface->childAt(x, y))
                 return iface;
