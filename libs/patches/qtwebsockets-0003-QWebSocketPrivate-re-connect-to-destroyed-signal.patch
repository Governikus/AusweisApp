From b7cee030d2638deaab8d1fd61342ae148b1d69f0 Mon Sep 17 00:00:00 2001
From: Timur Pocheptsov <timur.pocheptsov@qt.io>
Date: Fri, 23 May 2025 10:11:56 +0200
Subject: QWebSocketPrivate: re-connect to 'destroyed' signal
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

This commit amends 0c0f476150e501f311d054c67426b4d2304d2cbd.
That change in 'releaseConnections' was missing re-connecting
'destroyed'/'socketDestroyed'.

Task-number: QTBUG-135959
Change-Id: I20e83706e1cd3bd92f9d2ed08bc6ed2b8cb67d36
Reviewed-by: Mårten Nordheim <marten.nordheim@qt.io>
(cherry-picked from 1ff930de9573d90355a2097119fa6b24d41bbf5a)
---
 src/websockets/qwebsocket_p.cpp | 3 +++
 1 file changed, 3 insertions(+)

diff --git x/qtwebsockets/src/websockets/qwebsocket_p.cpp y/qtwebsockets/src/websockets/qwebsocket_p.cpp
index 4fbe3567673bcb94fe6cf8f05cf55fa040869a09..ee4220504ecc882e0c77669a44eb30fb825d70c0 100644
--- x/qtwebsockets/src/websockets/qwebsocket_p.cpp
+++ y/qtwebsockets/src/websockets/qwebsocket_p.cpp
@@ -740,6 +740,9 @@ void QWebSocketPrivate::releaseConnections(const QTcpSocket *pTcpSocket)
         // being disconnected with the wildcard disconnect below
         disconnect(pTcpSocket, &QObject::destroyed, this, &QWebSocketPrivate::socketDestroyed);
         pTcpSocket->disconnect();
+        // Re-connect, we need 'socketDestroyed' slot executed
+        QObjectPrivate::connect(pTcpSocket, &QObject::destroyed,
+                                this, &QWebSocketPrivate::socketDestroyed);
     }
     m_dataProcessor->disconnect();
 }
