diff --git x/qtbase/src/3rdparty/harfbuzz-ng/src/hb-subset-table.hh y/qtbase/src/3rdparty/harfbuzz-ng/src/hb-subset-table.hh
new file mode 100644
index 0000000000000000000000000000000000000000..66588ec6f8fb35af34fde84aad632f561347c3af
--- /dev/null
+++ y/qtbase/src/3rdparty/harfbuzz-ng/src/hb-subset-table.hh
@@ -0,0 +1,217 @@
