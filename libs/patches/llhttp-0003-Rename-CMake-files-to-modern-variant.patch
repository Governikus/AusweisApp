From 8337285e6bf5a7ed65083501c9daaa365c155336 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Andr=C3=A9=20Klitzing?= <aklitzing@gmail.com>
Date: Thu, 26 Mar 2026 10:51:40 +0100
Subject: Rename CMake files to modern variant

Modern CMake uses camel case. Also this avoids pollution
of PACKAGE_VERSION to global cmake space of the application.

This amends 068dab8950dc34599020c00d8ff7eef10dac7716 and
2ccad0e65da01c1380f2a054bbb6cebfc1389baa.

(cherry picked from commit dad7eadeb293e361d4628433bb79367b1a66f421)
---
 CMakeLists.txt               | 10 +++++-----
 cmake/llhttp-config.cmake.in | 19 -------------------
 cmake/llhttpConfig.cmake.in  | 19 +++++++++++++++++++
 3 files changed, 24 insertions(+), 24 deletions(-)
 delete mode 100644 cmake/llhttp-config.cmake.in
 create mode 100644 cmake/llhttpConfig.cmake.in

diff --git x/CMakeLists.txt y/CMakeLists.txt
index f4fd0faafb34dd8e97e0bc178b24ae69a257a26c..59a73dd0d2f26057855ffff10f34fe142206c7c3 100644
--- x/CMakeLists.txt
+++ y/CMakeLists.txt
@@ -100,19 +100,19 @@ if(TARGET llhttp_shared OR TARGET llhttp_static)
   )
 
   configure_package_config_file(
-    ${CMAKE_CURRENT_SOURCE_DIR}/cmake/llhttp-config.cmake.in
-    ${CMAKE_CURRENT_BINARY_DIR}/llhttp-config.cmake
+    ${CMAKE_CURRENT_SOURCE_DIR}/cmake/llhttpConfig.cmake.in
+    ${CMAKE_CURRENT_BINARY_DIR}/llhttpConfig.cmake
     INSTALL_DESTINATION ${CMAKE_INSTALL_LIBDIR}/cmake/llhttp
   )
 
   write_basic_package_version_file(
-    ${CMAKE_CURRENT_BINARY_DIR}/llhttp-config-version.cmake
+    ${CMAKE_CURRENT_BINARY_DIR}/llhttpConfigVersion.cmake
     COMPATIBILITY AnyNewerVersion
   )
 
   install(FILES
-    ${CMAKE_CURRENT_BINARY_DIR}/llhttp-config.cmake
-    ${CMAKE_CURRENT_BINARY_DIR}/llhttp-config-version.cmake
+    ${CMAKE_CURRENT_BINARY_DIR}/llhttpConfig.cmake
+    ${CMAKE_CURRENT_BINARY_DIR}/llhttpConfigVersion.cmake
     DESTINATION ${CMAKE_INSTALL_LIBDIR}/cmake/llhttp
   )
 endif()
diff --git x/cmake/llhttp-config.cmake.in y/cmake/llhttp-config.cmake.in
deleted file mode 100644
index 4d7e02c775230eddd8e1123aad22e11c1b914c3b..0000000000000000000000000000000000000000
--- x/cmake/llhttp-config.cmake.in
+++ /dev/null
@@ -1,19 +0,0 @@
-@PACKAGE_INIT@
-
-include("${CMAKE_CURRENT_LIST_DIR}/llhttp-targets.cmake")
-
-if(NOT TARGET llhttp::llhttp)
-  if(TARGET llhttp::llhttp_shared)
-    add_library(llhttp::llhttp INTERFACE IMPORTED)
-    set_property(TARGET llhttp::llhttp PROPERTY
-      INTERFACE_LINK_LIBRARIES llhttp::llhttp_shared
-    )
-  elseif(TARGET llhttp::llhttp_static)
-    add_library(llhttp::llhttp INTERFACE IMPORTED)
-    set_property(TARGET llhttp::llhttp PROPERTY
-      INTERFACE_LINK_LIBRARIES llhttp::llhttp_static
-    )
-  endif()
-endif()
-
-check_required_components(llhttp)
diff --git x/cmake/llhttpConfig.cmake.in y/cmake/llhttpConfig.cmake.in
new file mode 100644
index 0000000000000000000000000000000000000000..4d7e02c775230eddd8e1123aad22e11c1b914c3b
--- /dev/null
+++ y/cmake/llhttpConfig.cmake.in
@@ -0,0 +1,19 @@
+@PACKAGE_INIT@
+
+include("${CMAKE_CURRENT_LIST_DIR}/llhttp-targets.cmake")
+
+if(NOT TARGET llhttp::llhttp)
+  if(TARGET llhttp::llhttp_shared)
+    add_library(llhttp::llhttp INTERFACE IMPORTED)
+    set_property(TARGET llhttp::llhttp PROPERTY
+      INTERFACE_LINK_LIBRARIES llhttp::llhttp_shared
+    )
+  elseif(TARGET llhttp::llhttp_static)
+    add_library(llhttp::llhttp INTERFACE IMPORTED)
+    set_property(TARGET llhttp::llhttp PROPERTY
+      INTERFACE_LINK_LIBRARIES llhttp::llhttp_static
+    )
+  endif()
+endif()
+
+check_required_components(llhttp)
