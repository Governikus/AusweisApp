--- x/qtdeclarative/src/quick/accessible/qaccessiblequickview.cpp
+++ y/qtdeclarative/src/quick/accessible/qaccessiblequickview.cpp
@@ -10,6 +10,8 @@
 
 #include "qaccessiblequickitem_p.h"
 
+#include <QJSEngine>
+
 #if QT_CONFIG(accessibility)
 
 QT_BEGIN_NAMESPACE
@@ -79,6 +81,12 @@ QRect QAccessibleQuickWindow::rect() const
     return QRect(window()->x(), window()->y(), window()->width(), window()->height());
 }
 
+QString QAccessibleQuickWindow::uiLanguage() const
+{
+    QJSEngine *engine = qjsEngine(object());
+    return engine ? engine->uiLanguage() : QString();
+}
+
 QString QAccessibleQuickWindow::text(QAccessible::Text text) const
 {
     if (!window())
diff --git x/qtdeclarative/src/quick/accessible/qaccessiblequickview_p.h y/qtdeclarative/src/quick/accessible/qaccessiblequickview_p.h
index b4abb764e8613e3bff7f9bc3d368ad927ab8474c..7c6b53609dde1e8eed5cacfebbba3b530194b165 100644
--- x/qtdeclarative/src/quick/accessible/qaccessiblequickview_p.h
+++ y/qtdeclarative/src/quick/accessible/qaccessiblequickview_p.h
@@ -35,6 +35,7 @@ public:
     QAccessible::Role role() const override;
     QAccessible::State state() const override;
     QRect rect() const override;
+    QString uiLanguage() const override;
 
     int childCount() const override;
     int indexOfChild(const QAccessibleInterface *iface) const override;
